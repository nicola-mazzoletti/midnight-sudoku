{
    "name": "@nicolamazzoletti/midnight-sudoku-contract",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/sudoku.compact ./dist",
        "ci": "npm run compact && npm run typecheck && npm run lint && npm run build",
        "compact": "compact compile src/sudoku.compact ./src/managed/sudoku",
        "lint": "eslint src",
        "prepack": "npm build",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.5.0",
        "typescript": "^6.0.2"
    }
}
